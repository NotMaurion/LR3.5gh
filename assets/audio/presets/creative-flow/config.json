{
  "name": "Creative-Flow",
  "description": "Creative Flow preset with different configuration",
  "version": "1.0.0",
  "audioFiles": {
    "bass": "bass.wav",
    "mid": "mid.wav",
    "high": "high.wav",
    "tex": "tex.wav"
  },
  "defaultZones": [
    {
      "name": "Bass",
      "minNote": 21,
      "maxNote": 43,
      "baseNote": "C2",
      "volume": 0.8,
      "probability": 0.9
    },
    {
      "name": "Mid",
      "minNote": 44,
      "maxNote": 67,
      "baseNote": "C4",
      "volume": 0.7,
      "probability": 0.8
    },
    {
      "name": "High",
      "minNote": 68,
      "maxNote": 87,
      "baseNote": "C5",
      "volume": 0.6,
      "probability": 0.7
    },
    {
      "name": "Tex",
      "minNote": 21,
      "maxNote": 87,
      "baseNote": "C3",
      "volume": 0.5,
      "probability": 0.6
    }
  ],
  "defaultScaleFilter": {
    "enabled": false,
    "root": "C",
    "mode": "chromatic",
    "minOctave": 1,
    "maxOctave": 7
  },
  "defaultAudioEffects": {
    "reverb": {
      "enabled": true,
      "wet": 0.4,
      "dry": 0.6,
      "roomSize": 0.7,
      "dampening": 0.6,
      "preDelay": 0.02
    },
    "filter": {
      "enabled": false,
      "cutoff": 2000.0,
      "resonance": 0.0,
      "type": "lpf"
    },
    "envelope": {
      "enabled": true,
      "attack": 0.05,
      "decay": 0.1,
      "sustain": 0.9,
      "release": 0.5
    },
    "sustain": {
      "enabled": true,
      "duration": 2.0,
      "level": 0.8,
      "infinite": false
    }
  }
}