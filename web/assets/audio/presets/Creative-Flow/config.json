          "filter": { "frequency": 2200, "Q": 0.4 }
        },
        "tex": {
          "type": "square",
          "detune": 0,
          "harmonicContent": 0.8,
          "filter": { "frequency": 1800, "Q": 0.9 }
        }
      }
