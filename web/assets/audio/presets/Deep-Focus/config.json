  "defaultScaleFilter": {
    "enabled": true,
    "root": "C",
    "mode": "PENTATONIC_MAJOR",
    "minOctave": 1,
    "maxOctave": 7,
    "behavior": "snap"
  },

  "defaultAudioEffects": {
    "reverb": { "enabled": true, "wet": 0.40, "dry": 0.60, "roomSize": 0.70, "dampening": 0.60, "preDelay": 0.02 },
    "filter": { "enabled": false, "type": "lpf", "cutoff": 2000.0, "resonance": 0.0 },
    "envelope": { "enabled": true, "attack": 0.10, "decay": 0.20, "sustain": 0.80, "release": 1.00 },
    "sustain": { "enabled": true, "duration": 3.00, "level": 0.90, "infinite": false },
    "randomness": { "enabled": false, "pitchVariation": 0.10, "velocityVariation": 0.20, "timingVariation": 50.0, "sustainVariation": 0.30 },
    "simultaneousNotes": { "enabled": false, "maxNotes": 8, "overlapProbability": 0.30, "voiceStealing": true, "voiceStealThreshold": 0.50 },
    "globalVolume": 1.00,
    "audioQuality": "High",
    "layersEnabled": { "bass": true, "mid": true, "high": true, "tex": true }
  },

  "defaultMidiRules": {
    "velocityRule": { "enabled": false, "minVelocity": 0.0, "maxVelocity": 1.0, "curve": "linear" },
    "noteTransformation": { "enabled": false, "transpose": 0, "octaveShift": 0.0, "harmonize": false, "harmonyIntervals": [0, 7, 12] },
    "arpeggiator": { "enabled": false, "pattern": "up", "rate": 8.0, "octaves": 1, "syncToTempo": false, "gateLength": 0.5 },
    "quantization": { "enabled": false, "grid": "1/16", "strength": 0.8, "swing": false, "swingAmount": 0.5 },
    "midiThru": false,
    "recordMidi": false
