    },
    {
      "name": "Mid",
      "minNote": 44,
      "maxNote": 67,
      "baseNote": "C4",
      "volume": 0.70,
      "probability": 0.9,
      "texture": { "enabled": true, "loop": true, "lfoRateHz": 0.20, "lfoDepth": 0.50 }
    },
    {
      "name": "High",
      "minNote": 68,
      "maxNote": 87,
      "baseNote": "C5",
      "volume": 0.60,
      "probability": 0.9,
      "texture": { "enabled": true, "loop": true, "lfoRateHz": 0.20, "lfoDepth": 0.50 }
    },
    {
      "name": "Tex",
      "minNote": 21,
      "maxNote": 87,
      "baseNote": "C3",
      "volume": 0.50,
      "probability": 0.9,
      "texture": { "enabled": true, "loop": true, "lfoRateHz": 0.20, "lfoDepth": 0.50 }
